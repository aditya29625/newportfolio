# Example environment variables for EmailJS (DO NOT commit secrets)
# Copy this file to `.env.local` and replace the placeholders with your real keys.

VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here

# Optional: if your EmailJS template uses a variable name for recipient, you can set it here
# (the app currently forces the recipient to dhanrajsinghaditya@gmail.com)
# VITE_EMAILJS_TO_EMAIL=you@yourdomain.com
